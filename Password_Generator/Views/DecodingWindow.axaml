<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Password_Generator.DecodingWindow"
        Title="DecodingWindow"
        Icon="/Assets/avalonia-logo.ico"
        WindowState="Maximized"
        Background="#F5F7FA">

    <Window.Styles>
        <!-- Общие стили для кнопок -->
        <Style Selector="Button">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <Style Selector="Button:active">
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <!-- Общие стили для текстовых полей -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D7DE" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#4A90D9" />
        </Style>

        <!-- Общие стили для текстовых блоков -->
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#2D3748" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto, *" Background="#F5F7FA">

        <!-- ====== Левая панель с тенью ====== -->
        <Border Grid.Column="0"
                Width="180"
                Background="White"
                CornerRadius="0 12 12 0">
            <StackPanel Margin="20,30,20,20"
                        Spacing="12"
                        VerticalAlignment="Top">

                <TextBlock Text=" Меню"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#1A202C"
                           Margin="0,0,0,8" />

                <Button Content=" Генерация"
                        Click="onPasswordClick"
                        HorizontalAlignment="Stretch"
                        Background="#E2E8F0"
                        Foreground="#2D3748"
                        FontWeight="SemiBold" />

                <Button Content=" Шифрование"
                        Click="OnEncryptClick"
                        HorizontalAlignment="Stretch"
                        Background="#E2E8F0"
                        Foreground="#2D3748"
                        FontWeight="SemiBold" />

                <Button Content=" Расшифровка"
                        HorizontalAlignment="Stretch"
                        Background="#4A90D9"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="1"
                        BorderBrush="#4A90D9" />

                <!-- Разделитель -->
                <Border Height="1"
                        Background="#E2E8F0"
                        Margin="0,12,0,8" />


            </StackPanel>
        </Border>

        <!-- ====== Правая панель ====== -->
        <StackPanel Grid.Column="1"
                    Margin="40,30,50,30"
                    Spacing="18">

            <!-- Заголовок -->
            <TextBlock Text="Расшифровка пароля"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#1A202C"
                       Margin="0,0,0,4" />
            <TextBlock Text="Введите зашифрованные данные и ключ для расшифровки"
                       FontSize="14"
                       Foreground="#718096"
                       Margin="0,-8,0,12" />

            <!-- ====== Поле ввода пароля ====== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Введите пароль"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2D3748" />
                <TextBox Name="PasswordTextBox"
                         Height="42"
                         Watermark="Введите текст для шифрования"
                         Background="White"
                         BorderBrush="#D0D7DE" />
            </StackPanel>

            <!-- ====== Поле для ключа ====== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Ключ (необязательно)"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2D3748" />
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Name="KeyTextBox"
                             Grid.Column="0"
                             Height="42"
                             Watermark="Введите ключ или сгенерируйте"
                             Background="White"
                             BorderBrush="#D0D7DE" />
                </Grid>
            </StackPanel>

            <!-- ====== Кнопка расшифровки ====== -->
            <Button Click="onDecoding_Click"
                    Content="🔓 Расшифровать"
                    HorizontalAlignment="Left"
                    Background="LightGray"
                    Foreground="#2D3748"
                    FontWeight="SemiBold"
                    Padding="20,10" />

            <!-- ====== Поле вывода результата ====== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Результат"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2D3748" />
                <Border Background="#FFFFFF"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#D0D7DE"
                        Padding="12,8">
                    <TextBlock Name="OutputTextBox"
                               Foreground="#1A202C"
                               FontFamily="Courier New"
                               FontSize="14"
                               Height="60"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <!-- ====== Кнопка копирования (без обработчика) ====== -->
            <Button Content="📋 Копировать"
                    HorizontalAlignment="Left"
                    Background="#38A169"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Padding="24,10"
                    Width="160" />

        </StackPanel>
    </Grid>
</Window>