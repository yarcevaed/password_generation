<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Password_Generator.EncryptionWindow"
        Title="EncryptionWindow"
        Icon="/Assets/i.png"
        WindowState="Maximized"
        Background="#F5F7FA">

    <Window.Styles>
        <!-- Buttons -->
        <Style Selector="Button">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <Style Selector="Button:active">
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <!-- TextBoxes -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D7DE" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#4A90D9" />
        </Style>

        <!-- TextBlocks -->
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#2D3748" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#2D3748" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#1A202C" />
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#4A90D9" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="#3182CE" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto, *" Background="#F5F7FA">

        <!-- ====== Левая панель (с тенью через Border) ====== -->
<Border Grid.Column="0"
                Width="180"
                Background="White"
                CornerRadius="0 12 12 0"
                >
            <Grid RowDefinitions="Auto, *">
            <StackPanel Margin="20,30,20,20"
                        Spacing="12"
                        VerticalAlignment="Top">

                <TextBlock Text=" Меню"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#1A202C"
                           Margin="0,0,0,8" />

                <Button Content=" Генерация"
                        Click="onPasswordClick"
                        HorizontalAlignment="Stretch"
                        Background="#E2E8F0"
                        Foreground="#2D3748"
                        FontWeight="SemiBold" />

                <Button Content=" Шифрование"
                        
                        Background="#4A90D9"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        FontWeight="SemiBold" />

                <Button Content=" Расшифровка"
                        Click="onDecodingClick"
                        HorizontalAlignment="Stretch"
                        Background="#E2E8F0"
                        Foreground="#2D3748"
                        FontWeight="SemiBold" />

                <!-- Разделитель -->
                <Border Height="1"
                        Background="#E2E8F0"
                        Margin="0,12,0,8" />

            </StackPanel>
                            <StackPanel Grid.Row="1"
                            Margin="20,0,20,20"
                            Spacing="6">
                    <TextBlock Text="Сохранённые пароли"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#2D3748" />
                    <ScrollViewer MaxHeight="200"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="SavedPasswordsList"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ====== Правая панель ====== -->
        <StackPanel Grid.Column="1"
                    Margin="40,30,50,30"
                    Spacing="18">

            <!-- Заголовок -->
            <TextBlock Text="Управление паролями"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#1A202C"
                       Margin="0,0,0,4" />
            <TextBlock Text="Введите данные и выполните нужное действие"
                       FontSize="14"
                       Foreground="#718096"
                       Margin="0,-8,0,12" />

            <!-- ====== Поле ввода пароля ====== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Введите пароль"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2D3748" />
                <TextBox Name="PasswordTextBox"
                         Height="42"
                         Watermark="Введите текст для шифрования"
                         Background="White"
                         BorderBrush="#D0D7DE" />
            </StackPanel>

            <!-- ====== Поле ключа ====== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Ключ (необязательно)"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2D3748" />
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Name="KeyTextBox"
                             Grid.Column="0"
                             Height="42"
                             Watermark="Введите ключ"
                             Background="White"
                             BorderBrush="#D0D7DE" />
                </Grid>
            </StackPanel>

            <!-- ====== Кнопка генерации ключа ====== -->
            <Button Click="onGenerate_Click"
                    Content="🔐 Зашифровать"
                    HorizontalAlignment="Left"
                    Background="LightGray"
                    Foreground="#2D3748"
                    FontWeight="SemiBold"
                    Padding="20,10" />

            <!-- ====== Поле вывода результата ====== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Результат"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2D3748" />
                <Border Background="#FFFFFF"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#D0D7DE"
                        Padding="12,8">
                    <TextBlock Name="OutputTextBox"
                               Foreground="#1A202C"
                               FontFamily="Courier New"
                               FontSize="14"
                               Height="60"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <!-- ====== Кнопка копирования ====== -->
            <Button Content="📋 Копировать"
                    Click="onCopyClick"
                    HorizontalAlignment="Left"
                    Background="#38A169"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Padding="24,10"
                    Width="160" />

        </StackPanel>
    </Grid>
</Window>